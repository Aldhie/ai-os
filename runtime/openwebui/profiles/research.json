{
  "_meta": {
    "profile": "research",
    "version": "1.0.0",
    "description": "Optimized for multi-source research synthesis, literature review, and knowledge-intensive tasks. Maximum RAG budget.",
    "use_when": ["research", "literature_review", "multi_source_synthesis", "topic_survey"],
    "nim_model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
    "rpm_impact": "high",
    "last_updated": "2026-07-21"
  },
  "parameters": {
    "temperature": 0.5,
    "top_p": 0.90,
    "top_k": 30,
    "max_tokens": 2000,
    "presence_penalty": 0.1,
    "frequency_penalty": 0.05,
    "stream": true
  },
  "thinking": {
    "type": "enabled",
    "budget_tokens": 10000
  },
  "context": {
    "expected_input_tokens": 8000,
    "total_context_budget": 32000,
    "history_turns": 3,
    "memory_top_k": 3,
    "rag_top_k": 8,
    "rag_min_score": 0.60
  },
  "latency": {
    "expected_p50_ms": 25000,
    "expected_p95_ms": 50000,
    "ttft_target_ms": 3000
  },
  "token_usage": {
    "expected_thinking_tokens": 8000,
    "expected_output_tokens": 1500
  },
  "runtime": {
    "memory": true,
    "knowledge": true,
    "planner": true,
    "critic": false,
    "reflection": true,
    "tool_budget": 3
  },
  "rpm_optimization": {
    "batch_tool_results": true,
    "cache_rag": true,
    "parallel_context_loading": true,
    "reduce_history_on_large_rag": true
  }
}
