{
  "$schema": "https://ai-os.dev/schemas/runtime/model.json",
  "_meta": {
    "version": "1.0.0",
    "sprint": "C",
    "last_updated": "2026-07-21",
    "why": "Single source of truth for the AI-OS model identity in Open WebUI. All other configs reference this model_id."
  },
  "model_id": "ai-os-nemotron-ultra",
  "display_name": "AI-OS · Nemotron Ultra",
  "description": "Production reasoning intelligence. NVIDIA Nemotron-3-Ultra-550B-A55B via NIM Free Tier. Optimized for architecture, coding, analysis, and long technical conversations.",
  "base_model": {
    "provider": "nvidia",
    "api_type": "openai_compatible",
    "base_url": "https://integrate.api.nvidia.com/v1",
    "model_name": "nvidia/nemotron-ultra-253b-v1",
    "api_key_env": "NVIDIA_NIM_API_KEY"
  },
  "system_prompt_ref": "runtime/openwebui/model/compiled_prompt_v2.md",
  "capabilities": {
    "streaming": true,
    "function_calling": false,
    "vision": false,
    "thinking": true,
    "extended_context": true,
    "max_context_tokens": 1000000,
    "safe_context_tokens": 65536
  },
  "tier": {
    "name": "free",
    "rpm_limit": 32,
    "tpm_limit": null,
    "concurrent_requests": 1,
    "shared_infrastructure": true
  },
  "tags": ["ai-os", "nemotron", "nvidia", "production", "reasoning"]
}
