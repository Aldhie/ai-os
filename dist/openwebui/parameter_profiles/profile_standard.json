{
  "_meta": {
    "profile": "standard",
    "description": "Most conversational tasks. Light thinking enabled.",
    "use_when": ["casual", "explanation", "recommendation", "business"],
    "version": "1.0.0"
  },
  "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
  "temperature": 0.6,
  "top_p": 0.9,
  "max_tokens": 1000,
  "stream": true,
  "extra_body": {
    "thinking": {
      "type": "enabled",
      "budget_tokens": 5000
    }
  }
}
