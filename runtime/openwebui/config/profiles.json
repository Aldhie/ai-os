      "reasoning_budget": 4096,
      "expected_context_tokens": 8192,
      "expected_latency_ms": 8000,
      "expected_output_tokens": 600,
      "memory_strategy": "load_if_relevant",
      "knowledge_strategy": "skip_unless_collection_loaded",
      "planner_usage": "off",
      "critic_usage": "off",
      "reflection_usage": "off",
      "tool_strategy": "minimum",
      "rpm_optimization": "batch_tools_before_nim",
      "why": "Discussion requires natural, fluid responses. High temperature preserves expressiveness. No reflection or critic — overhead unjustified for conversational turns."
    },
    "coding": {
      "temperature": 0.2,
      "top_p": 0.90,
      "top_k": 20,
      "max_tokens": 4096,
      "presence_penalty": 0.0,
