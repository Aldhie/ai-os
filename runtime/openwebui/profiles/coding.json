{
  "_meta": {
    "profile": "coding",
    "version": "1.0.0",
    "description": "Optimized for code generation, review, and explanation. Lower temperature for determinism. Moderate thinking for logic verification.",
    "use_when": ["code_generation", "code_review", "explanation_of_code", "refactoring"],
    "nim_model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
    "rpm_impact": "medium",
    "last_updated": "2026-07-21"
  },
  "parameters": {
    "temperature": 0.3,
    "top_p": 0.85,
    "top_k": 20,
    "max_tokens": 2500,
    "presence_penalty": 0.0,
    "frequency_penalty": 0.05,
    "stream": true
  },
  "thinking": {
    "type": "enabled",
    "budget_tokens": 8000
  },
  "context": {
    "expected_input_tokens": 5000,
    "total_context_budget": 24000,
    "history_turns": 5,
    "memory_top_k": 3,
    "rag_top_k": 5,
    "rag_min_score": 0.70
  },
  "latency": {
    "expected_p50_ms": 18000,
    "expected_p95_ms": 35000,
    "ttft_target_ms": 2500
  },
  "token_usage": {
    "expected_thinking_tokens": 7000,
    "expected_output_tokens": 1500
  },
  "runtime": {
    "memory": true,
    "knowledge": true,
    "planner": false,
    "critic": true,
    "reflection": false,
    "tool_budget": 2
  },
  "rpm_optimization": {
    "disable_planner": true,
    "disable_reflection": true,
    "cache_memory": true,
    "cache_rag": true,
    "batch_tool_results": true
  }
}
