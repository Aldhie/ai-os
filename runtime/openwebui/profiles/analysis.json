{
  "profile_id": "analysis",
  "version": "1.0.0",
  "description": "Optimised for data analysis, trade-off evaluation, and comparative reasoning.",
  "model": "nvidia/nemotron-3-ultra-550b-a55b",
  "parameters": {
    "temperature": 0.4,
    "top_p": 0.9,
    "top_k": 35,
    "max_tokens": 2048,
    "presence_penalty": 0.05,
    "frequency_penalty": 0.1,
    "stream": true
  },
  "thinking": {
    "enable_thinking": true,
    "reasoning_budget": 8192,
    "rationale": "Analysis tasks require weighing multiple variables and deriving structured conclusions. 8K budget handles most comparative frameworks without excessive latency."
  },
  "context": {
    "expected_input_tokens": 2000,
    "expected_output_tokens": 1800,
    "expected_total_tokens": 3800
  },
  "latency": {
    "expected_ttft_ms": 10000,
    "expected_total_ms": 30000
  },
  "memory_strategy": {
    "load_memory": true,
    "min_relevance_score": 0.70,
    "max_memory_tokens": 400
  },
  "knowledge_strategy": {
    "load_rag": true,
    "top_k_chunks": 5,
    "min_similarity_score": 0.65
  },
  "planner_usage": "conditional_on_multi_phase_analysis",
  "critic_usage": true,
  "reflection_usage": true,
  "tool_strategy": {
    "github": false,
    "brain_memory": true,
    "web_search": "conditional_on_data_freshness",
    "calculator": true,
    "rationale": "Analysis may require precise calculations and fresh data. Calculator always available; web search gated on freshness requirement."
  },
  "rpm_optimization": {
    "strategy": "batch_all_tools_before_nim",
    "batch_tools": true,
    "max_rpm_per_session_minute": 5
  }
}
