{
  "_schema": "ai-os/owu-model-config",
  "_version": "1.0.0",
  "_sprint": "C",
  "_why": "Defines the Open WebUI model entity for AI-OS Nemotron Ultra. This is the root config imported into OWU via Admin > Models > + New Model.",

  "id": "ai-os-nemotron-ultra",
  "name": "AI-OS · Nemotron Ultra",
  "base_model_id": "nvidia/nemotron-3-ultra-550b",
  "description": "Production reasoning intelligence of AI-OS. Optimised for architecture, coding, analysis, and long technical discussions. Powered by NVIDIA Nemotron-3-Ultra-550B via NIM Free Tier.",

  "meta": {
    "tags": ["production", "reasoning", "coding", "architecture", "analysis"],
    "capabilities": {
      "vision": false,
      "file_handling": true,
      "code_execution": false,
      "tools": true,
      "citations": true
    }
  },

  "params": {
    "system": "[PASTE compiled_prompt_v2.md contents here — see dist/openwebui/compiled_prompt_v2.md]",
    "stream_response": true,
    "function_calling": "auto"
  },

  "_filters": [
    { "priority": 1, "name": "AI-OS RPM Guard",                "file": "dist/openwebui/filters/rpm_guard.py" },
    { "priority": 2, "name": "AI-OS Credential Scrub",         "file": "dist/openwebui/filters/credential_scrub.py" },
    { "priority": 3, "name": "AI-OS Profile Selector",         "file": "dist/openwebui/filters/profile_selector.py" },
    { "priority": 4, "name": "AI-OS Context Budget Enforcer",  "file": "dist/openwebui/filters/context_budget_enforcer.py" },
    { "priority": 5, "name": "AI-OS Response Quality Monitor", "file": "dist/openwebui/filters/response_quality_monitor.py" }
  ]
}
