{
  "_meta": {
    "profile": "coding",
    "description": "Optimized for code generation, review, and explanation. Prioritizes correctness and completeness over conversational warmth. Reflection enabled to catch logic errors before output.",
    "version": "1.0.0",
    "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
    "optimized_for": "NVIDIA Cloud NIM Free Tier",
    "last_updated": "2026-07-21"
  },
  "parameters": {
    "temperature": 0.3,
    "top_p": 0.85,
    "top_k": 40,
    "max_tokens": 2500,
    "presence_penalty": 0.0,
    "frequency_penalty": 0.05,
    "stream": true
  },
  "thinking": {
    "type": "enabled",
    "budget_tokens": 8000
  },
  "context": {
    "expected_input_tokens": 4000,
    "expected_output_tokens": 1500,
    "expected_thinking_tokens": 6000,
    "total_per_turn_estimate": 11500
  },
  "latency": {
    "expected_ttft_ms": 3000,
    "expected_total_ms": 20000,
    "p95_total_ms": 35000
  },
  "runtime": {
    "memory_strategy": "load_project_context",
    "knowledge_strategy": "load_for_library_queries",
    "planner": false,
    "critic": false,
    "reflection": true,
    "tool_strategy": "github_and_knowledge_only",
    "history_turns_verbatim": 5,
    "history_turns_compressed": 8
  },
  "rpm_optimization": {
    "target_rpm": 3,
    "tool_calls_per_turn_max": 2,
    "batch_tool_calls": true,
    "cache_memory": true,
    "cache_rag": true
  },
  "prompt_modules": [1, 2, 3, 4, 6, 8, 9, 10, 11, 12, 13, 14],
  "use_when": [
    "code generation",
    "code review",
    "refactoring",
    "unit test generation",
    "code explanation",
    "API design"
  ]
}
