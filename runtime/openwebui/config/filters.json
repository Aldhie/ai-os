{
  "_schema": "ai-os/runtime-config/filters",
  "_version": "1.0.0",
  "_sprint": "C",
  "_why": "Registry of all Open WebUI Python Filters in this runtime. Defines install order, dependencies, and assignment to the AI-OS model. Use this as the authoritative checklist when deploying to a new Open WebUI instance.",

  "model_assignment": "ai-os-nemotron-ultra",

  "filters": [
    {
      "id": "rpm_guard",
      "name": "AI-OS RPM Guard",
      "file": "runtime/openwebui/filters/rpm_guard.py",
      "dist_file": "dist/openwebui/filters/rpm_guard.py",
      "type": "filter",
      "direction": "inlet",
      "install_order": 1,
      "enabled_default": true,
      "depends_on": [],
      "valves": {
        "max_rpm": 32,
        "window_seconds": 60,
        "enabled": true
      },
      "why": "Must be first. Cheapest possible gate. Rejects at Open WebUI layer before any downstream processing consumes resources."
    },
    {
      "id": "credential_scrub",
      "name": "AI-OS Credential Scrub",
      "file": "runtime/openwebui/filters/credential_scrub.py",
      "dist_file": "dist/openwebui/filters/credential_scrub.py",
      "type": "filter",
      "direction": "inlet",
      "install_order": 2,
      "enabled_default": true,
      "depends_on": [],
      "valves": {
        "enabled": true,
        "redaction_placeholder": "[REDACTED-CREDENTIAL]"
      },
      "why": "Must run before profile_selector to prevent secret tokens from being injected into NIM API call."
    },
    {
      "id": "profile_selector",
      "name": "AI-OS Profile Selector",
      "file": "runtime/openwebui/filters/profile_selector.py",
      "dist_file": "dist/openwebui/filters/profile_selector.py",
      "type": "filter",
      "direction": "inlet",
      "install_order": 3,
      "enabled_default": true,
      "depends_on": ["credential_scrub"],
      "writes_to_body": ["_ai_os_task_class", "_ai_os_profile", "options.temperature", "options.num_predict", "extra_body.reasoning_budget"],
      "valves": {
        "enabled": true,
        "default_profile": "discussion"
      },
      "why": "Task classification drives all downstream parameter selection. Must run after credential_scrub to ensure clean message content."
    },
    {
      "id": "context_budget_enforcer",
      "name": "AI-OS Context Budget Enforcer",
      "file": "runtime/openwebui/filters/context_budget_enforcer.py",
      "dist_file": "dist/openwebui/filters/context_budget_enforcer.py",
      "type": "filter",
      "direction": "inlet",
      "install_order": 4,
      "enabled_default": true,
      "depends_on": ["profile_selector"],
      "valves": {
        "enabled": true,
        "max_context_tokens": 65536,
        "min_history_turns": 3
      },
      "why": "Final gate before NIM call. Enforces hard context ceiling to prevent latency degradation and overflow on Free Tier."
    },
    {
      "id": "response_quality_monitor",
      "name": "AI-OS Response Quality Monitor",
      "file": "runtime/openwebui/filters/response_quality_monitor.py",
      "dist_file": "dist/openwebui/filters/response_quality_monitor.py",
      "type": "filter",
      "direction": "outlet",
      "install_order": 5,
      "enabled_default": true,
      "depends_on": ["profile_selector"],
      "reads_from_body": ["_ai_os_task_class", "_ai_os_rag_used"],
      "writes_to_body": ["_ai_os_quality"],
      "valves": {
        "enabled": true,
        "append_quality_metadata": false
      },
      "why": "Quality metadata written to body enables benchmark harness to score without re-querying NIM. Set append_quality_metadata=true for debug runs."
    }
  ]
}
