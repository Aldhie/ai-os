      "critic_usage": "off",
      "reflection_usage": "off",
      "tool_strategy": "none",
      "rpm_optimization": "single_nim_call_no_tools",
      "why": "Creative tasks benefit from maximum temperature diversity. High presence/frequency penalty prevents repetitive patterns. No tools, no reflection — overhead kills creative flow and the task class does not require precision."
    },
    "research": {
      "temperature": 0.5,
      "top_p": 0.95,
      "top_k": 50,
      "max_tokens": 8192,
      "presence_penalty": 0.2,
      "frequency_penalty": 0.1,
