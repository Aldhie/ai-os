      "expected_context_tokens": 12288,
      "expected_latency_ms": 12000,
      "expected_output_tokens": 1200,
      "memory_strategy": "load_coding_standards_only",
      "knowledge_strategy": "load_if_api_or_library_relevant",
      "planner_usage": "off",
      "critic_usage": "on_security_critical_code",
      "reflection_usage": "on",
      "tool_strategy": "minimum",
      "rpm_optimization": "batch_tools_before_nim",
      "why": "Low temperature is critical for code generation — randomness produces syntax errors and logic bugs. Reflection mandatory to catch logical errors before output. Frequency/presence penalty 0 — code requires exact repetition of syntax patterns."
    },
    "architecture": {
      "temperature": 0.4,
      "top_p": 0.95,
      "top_k": 40,
      "max_tokens": 6144,
      "presence_penalty": 0.2,
      "frequency_penalty": 0.1,
      "reasoning_budget": 8192,
      "expected_context_tokens": 20480,
      "expected_latency_ms": 20000,
      "expected_output_tokens": 2500,
      "memory_strategy": "load_project_constraints_and_decisions",
      "knowledge_strategy": "load_domain_collection",
      "planner_usage": "on",
      "critic_usage": "mandatory",
      "reflection_usage": "mandatory",
      "tool_strategy": "github_plus_knowledge",
      "rpm_optimization": "batch_tools_before_nim",
      "why": "Architecture decisions have long-term consequences. Mandatory critic and reflection catch blind spots. High reasoning_budget (8192) enables deep trade-off analysis. max_tokens 6144 covers full design documents."
