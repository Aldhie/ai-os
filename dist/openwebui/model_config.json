{
  "_schema": "ai-os/dist/model-config",
  "_version": "2.0.0",
  "_sprint": "C",
  "_changelog": "v2: corrected model ID to nvidia/nemotron-3-ultra-550b, corrected rpm_ceiling to 32, aligned context limits with NIM Free Tier empirical ceiling of 65536 tokens.",

  "id": "ai-os-nemotron-ultra",
  "name": "AI-OS · Nemotron Ultra",
  "description": "Production AI-OS runtime. Nemotron-3-Ultra-550B via NIM Free Tier. Optimised for reasoning, architecture, and code.",

  "connection": {
    "type": "openai_compatible",
    "base_url": "https://integrate.api.nvidia.com/v1",
    "api_key_env": "NVIDIA_API_KEY",
    "model_name": "nvidia/nemotron-3-ultra-550b"
  },

  "capabilities": {
    "thinking": true,
    "streaming": true,
    "tool_use": true,
    "vision": false,
    "context_window_tokens": 1048576,
    "free_tier_safe_context_tokens": 65536,
    "max_output_tokens": 32768
  },

  "nim_free_tier": {
    "rpm_ceiling": 32,
    "concurrent_requests": 1,
    "sla": "none",
    "infrastructure": "shared"
  },

  "system_prompt": "dist/openwebui/compiled_prompt_v2.md",
  "filters": "dist/openwebui/filters/",
  "profiles": "dist/openwebui/parameter_profiles/"
}
