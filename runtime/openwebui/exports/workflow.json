{
  "_meta": {
    "artifact": "workflow.json",
    "version": "1.0.0",
    "spec_ref": "runtime/openwebui/workflows/workflow_runtime.md"
  },
  "pipeline": [
    { "stage": 1, "name": "session_init", "skippable": false, "token_budget": 0 },
    { "stage": 2, "name": "intent_detection", "skippable": false, "token_budget": 0 },
    { "stage": 3, "name": "planner", "skippable": true, "skip_condition": "intent in [factual, general]", "token_budget": 2000 },
    { "stage": 4, "name": "memory_decision", "skippable": true, "skip_condition": "no_user_id OR factual intent", "token_budget": 500 },
    { "stage": 5, "name": "knowledge_decision", "skippable": true, "skip_condition": "rag_disabled in profile", "token_budget": 4000 },
    { "stage": 6, "name": "tool_decision", "skippable": true, "skip_condition": "no_tool_justified", "token_budget": 1000 },
    { "stage": 7, "name": "reasoning", "skippable": false, "token_budget": 32000 },
    { "stage": 8, "name": "critic", "skippable": true, "skip_condition": "mode_0 OR response_lt_100_tokens", "token_budget": 1000 },
    { "stage": 9, "name": "reflection", "skippable": true, "skip_condition": "mode_0 OR conversational", "token_budget": 500 },
    { "stage": 10, "name": "response", "skippable": false, "token_budget": 8192 }
  ]
}
