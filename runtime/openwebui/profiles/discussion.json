{
  "_meta": {
    "profile": "discussion",
    "description": "Optimized for deep, substantive conversational analysis. Balances reasoning depth with conversational flow. Supports long multi-turn discussions without latency degradation.",
    "version": "1.0.0",
    "model": "nvidia/llama-3.1-nemotron-ultra-253b-v1",
    "optimized_for": "NVIDIA Cloud NIM Free Tier",
    "last_updated": "2026-07-21"
  },
  "parameters": {
    "temperature": 0.65,
    "top_p": 0.92,
    "top_k": 50,
    "max_tokens": 1200,
    "presence_penalty": 0.1,
    "frequency_penalty": 0.1,
    "stream": true
  },
  "thinking": {
    "type": "enabled",
    "budget_tokens": 6000
  },
  "context": {
    "expected_input_tokens": 3000,
    "expected_output_tokens": 800,
    "expected_thinking_tokens": 4000,
    "total_per_turn_estimate": 7800
  },
  "latency": {
    "expected_ttft_ms": 2500,
    "expected_total_ms": 14000,
    "p95_total_ms": 25000
  },
  "runtime": {
    "memory_strategy": "load_on_user_reference",
    "knowledge_strategy": "load_on_domain_query",
    "planner": false,
    "critic": false,
    "reflection": false,
    "tool_strategy": "minimum_necessary",
    "history_turns_verbatim": 5,
    "history_turns_compressed": 10
  },
  "rpm_optimization": {
    "target_rpm": 2,
    "tool_calls_per_turn_max": 2,
    "batch_tool_calls": true,
    "cache_memory": true,
    "cache_rag": true
  },
  "use_when": [
    "strategic discussion",
    "opinion and analysis",
    "business conversation",
    "exploration of ideas",
    "multi-turn deep dive"
  ]
}
