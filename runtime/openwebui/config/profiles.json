      "temperature": 0.1,
      "top_p": 0.85,
      "top_k": 10,
      "max_tokens": 3072,
      "presence_penalty": 0.0,
      "frequency_penalty": 0.0,
      "reasoning_budget": 6144,
      "expected_context_tokens": 16384,
      "expected_latency_ms": 15000,
      "expected_output_tokens": 1000,
