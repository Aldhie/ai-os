{
  "$schema": "https://ai-os.dev/schemas/runtime/filters.json",
  "_meta": {
    "version": "1.0.0",
    "sprint": "C",
    "last_updated": "2026-07-21",
    "why": "Filter chain registry. Defines installation order, type, source path, and valve defaults for all Open WebUI Python filters."
  },
  "filter_chain": [
    {
      "priority": 1,
      "id": "rpm_guard",
      "display_name": "AI-OS RPM Guard",
      "type": "inlet",
      "source": "runtime/openwebui/filters/rpm_guard.py",
      "dist": "dist/openwebui/filters/rpm_guard.py",
      "enabled": true,
      "valves": {
        "max_rpm": 32,
        "window_seconds": 60,
        "enabled": true
      }
    },
    {
      "priority": 2,
      "id": "credential_scrub",
      "display_name": "AI-OS Credential Scrub",
      "type": "inlet",
      "source": "runtime/openwebui/filters/credential_scrub.py",
      "dist": "dist/openwebui/filters/credential_scrub.py",
      "enabled": true,
      "valves": {
        "enabled": true,
        "redaction_placeholder": "[REDACTED-CREDENTIAL]"
      }
    },
    {
      "priority": 3,
      "id": "profile_selector",
      "display_name": "AI-OS Profile Selector",
      "type": "inlet",
      "source": "runtime/openwebui/filters/profile_selector.py",
      "dist": "dist/openwebui/filters/profile_selector.py",
      "enabled": true,
      "valves": {
        "enabled": true,
        "default_profile": "discussion"
      }
    },
    {
      "priority": 4,
      "id": "context_budget_enforcer",
      "display_name": "AI-OS Context Budget Enforcer",
      "type": "inlet",
      "source": "runtime/openwebui/filters/context_budget_enforcer.py",
      "dist": "dist/openwebui/filters/context_budget_enforcer.py",
      "enabled": true,
      "valves": {
        "enabled": true,
        "max_context_tokens": 65536,
        "tokens_per_char_estimate": 0.25,
        "min_history_turns": 3
      }
    },
    {
      "priority": 5,
      "id": "response_quality_monitor",
      "display_name": "AI-OS Quality Monitor",
      "type": "outlet",
      "source": "runtime/openwebui/filters/response_quality_monitor.py",
      "dist": "dist/openwebui/filters/response_quality_monitor.py",
      "enabled": true,
      "valves": {
        "enabled": true,
        "append_quality_metadata": false
      }
    }
  ]
}
